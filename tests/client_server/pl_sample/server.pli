 main: proc options(main);
 %include web_socket;

   dcl server_fd socket_fd_t;
   dcl client_fd socket_fd_t;
   dcl port port_t init(8090);
   dcl backlog backlog_t init(5);
   dcl buffer char(4096);
   dcl bytes size_t;
   dcl message char(256) varying;

   /* create socket */
   put skip list('Creating socket...');
   server_fd = socket(AF.INET, TYPE.STREAM, 0);
   if server_fd < 0 then do;
     put skip list(' socket failed');
     stop;
   end;

   /* bind to port */
   put skip list('Binding to port...');
    if bind(server_fd, port, AF.INET, INADDR.ANY) < 0 then do;
     put skip list(' bind failed');
     stop;
   end;

   /* listen for connections */
   put skip list('Listening for connections...');
   if listen(server_fd, backlog) < 0 then do;
     put skip list(' listen failed');
     stop;
   end;

   put skip list('Server listening on port', port);

   /* accept one client */
   put skip list('Accepting connections...');
   client_fd = accept(server_fd);
   if client_fd < 0 then do;
     put skip list(' accept failed');
     stop;
   end;

   put skip list('Client connected');

   /* read what the client sent */
   put skip list('Reading from client...');
   bytes = read(client_fd, addr(buffer), length(buffer));
   if bytes < 0 then do;
     put skip list(' read failed');
     stop;
   end;

   if bytes > 0 then do;
     message = substr(buffer, 1, bytes);
     put skip list('Received:', message);

     /* echo it back */
     put skip list('Writing to client...');
     bytes = write(client_fd, addr(buffer), bytes);
     if bytes < 0 then do;
       put skip list(' write failed');
       stop;
     end;

     put skip list('Echoed back');
   end;

   call close(client_fd);
   call close(server_fd);
 end main;
