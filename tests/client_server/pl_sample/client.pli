 main: proc options(main);
 %include web_socket;

   dcl sock_fd socket_fd_t;
   dcl port port_t init(8090);
   dcl message char(256) varying;
   dcl host_str char(256);
   dcl c_host char(256);
   dcl msg_data char(256);
   dcl buffer char(4096);
   dcl bytes size_t;

   host_str = '127.0.0.1';
   message = 'hello from pl_i_sample' || LINE_END;

   /* create socket */
   sock_fd = socket(AF.INET, TYPE.STREAM, 0);
   if sock_fd < 0 then do;
     put skip list('socket failed');
     stop;
   end;

   /* connect to server */
   c_host = trim(host_str) || '00'x;
   if connect(addr(c_host), port, sock_fd, AF.INET) < 0 then do;
     put skip list('connect failed');
     stop;
   end;

   put skip list('Connected to server');

   /* send message */
   msg_data = message;
   bytes = write(sock_fd, addr(msg_data), length(message));
   if bytes < 0 then do;
     put skip list('write failed');
     stop;
   end;

   put skip list('Sent:', message);

   /* read echo response */
   bytes = read(sock_fd, addr(buffer), length(buffer));
   if bytes < 0 then do;
     put skip list('read failed');
     stop;
   end;

   if bytes > 0 then
     put skip list('Received echo:', substr(buffer, 1, bytes));

   call close(sock_fd);
 end main;
